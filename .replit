modules = ["nodejs-20", "web", "python-3.12", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"
JWT_SECRET = "replit-dev-jwt-secret-change-in-production"
VITE_APP_TITLE = "ERP RH & DP - FC Engenharia"
VITE_APP_LOGO = "/fc-logo.png"
NODE_ENV = "development"
OAUTH_SERVER_URL = "https://forge.manus.ai"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 NODE_ENV=development pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
run = ["node", "dist/index.js"]
build = ["pnpm", "build"]
