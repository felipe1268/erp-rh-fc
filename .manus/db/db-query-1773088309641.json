{
  "query": "\n-- Contar ativos por empresa (FC + JF = construtoras)\nSELECT c.id, c.nomeFantasia, \n  COUNT(e.id) as total_ativos\nFROM employees e\nJOIN companies c ON e.companyId = c.id\nWHERE e.deletedAt IS NULL \n  AND e.status NOT IN ('Desligado', 'Lista_Negra')\nGROUP BY c.id, c.nomeFantasia\nORDER BY c.nomeFantasia;\n",
